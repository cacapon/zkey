{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "strict": true
  },
  "include": ["src/**/*.ts"]
}
